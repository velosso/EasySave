<Window x:Class="EasySave.GUI.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="EasySave — Settings"
        Height="340" Width="460"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Log Format -->
        <TextBlock Grid.Row="0" Text="Log format :"
                   FontWeight="SemiBold" Margin="0,0,0,4"/>
        <ComboBox Grid.Row="1"
                  SelectedValue="{Binding LogFormat}"
                  Height="28" Margin="0,0,0,12">
            <ComboBoxItem Content="json"/>
            <ComboBoxItem Content="xml"/>
        </ComboBox>

        <!-- Business Software -->
        <TextBlock Grid.Row="2"
                   Text="Business software process name (e.g. calc) :"
                   FontWeight="SemiBold" Margin="0,0,0,4"/>
        <TextBox Grid.Row="3"
                 Text="{Binding BusinessSoftware,
                        UpdateSourceTrigger=PropertyChanged}"
                 Height="28" Margin="0,0,0,12"/>

        <!-- Encrypted Extensions -->
        <TextBlock Grid.Row="4"
                   Text="Extensions to encrypt (e.g. .pdf, .docx) :"
                   FontWeight="SemiBold" Margin="0,0,0,4"/>
        <TextBox Grid.Row="5"
                 Text="{Binding EncryptedExtensions,
                        UpdateSourceTrigger=PropertyChanged}"
                 Height="28" VerticalAlignment="Top" Margin="0,0,0,0"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="6" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Cancel"
                    Command="{Binding CancelCommand}"
                    Width="90" Height="32" Margin="0,0,8,0"/>
            <Button Content="Save settings"
                    Command="{Binding SaveCommand}"
                    Width="120" Height="32"
                    Background="#1D9E75" Foreground="White"
                    FontWeight="SemiBold"/>
        </StackPanel>
    </Grid>
</Window>